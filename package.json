{
  "name": "fdb-tracker",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "db:fix-households": "npx tsx scripts/apply-households-migration.ts",
    "db:fix-profiles": "npx tsx scripts/apply-profiles-migration.ts",
    "db:fix-income-config": "npx tsx scripts/apply-income-config-migration.ts",
    "db:reset": "npx tsx scripts/reset-supabase.ts",
    "dev": "NODE_OPTIONS='--disable-warning=DEP0169' next dev --turbopack",
    "build": "NODE_OPTIONS='--disable-warning=DEP0169' next build",
    "start": "NODE_OPTIONS='--disable-warning=DEP0169' next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-currency-input-field": "^4.0.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "telegraf": "^4.16.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
